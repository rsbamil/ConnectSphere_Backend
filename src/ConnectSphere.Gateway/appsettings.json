{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**remainder}"
        },
        "Transforms": []
      },
      "post-route": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "/api/posts/{**remainder}"
        },
        "Transforms": []
      },
      "like-route": {
        "ClusterId": "like-cluster",
        "Match": {
          "Path": "/api/likes/{**remainder}"
        },
        "Transforms": []
      },
      "comment-route": {
        "ClusterId": "comment-cluster",
        "Match": {
          "Path": "/api/comments/{**remainder}"
        },
        "Transforms": []
      },
      "follow-route": {
        "ClusterId": "follow-cluster",
        "Match": {
          "Path": "/api/follows/{**remainder}"
        },
        "Transforms": []
      },
      "notif-route": {
        "ClusterId": "notif-cluster",
        "Match": {
          "Path": "/api/notifications/{**remainder}"
        },
        "Transforms": []
      },
      "feed-route": {
        "ClusterId": "feed-cluster",
        "Match": {
          "Path": "/api/feed/{**remainder}"
        },
        "Transforms": []
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-auth-service.onrender.com"
          }
        }
      },
      "post-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-post-service.onrender.com"
          }
        }
      },
      "like-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-like-service.onrender.com"
          }
        }
      },
      "comment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-comment-service.onrender.com"
          }
        }
      },
      "follow-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-follow-service.onrender.com"
          }
        }
      },
      "notif-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-notif-service.onrender.com"
          }
        }
      },
      "feed-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://cs-feed-service.onrender.com"
          }
        }
      }
    }
  }
}